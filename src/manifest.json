{
  "name": "Classtab.org Dark Mode",
  "version": "1.1.0",
  "author": "Sean Free",
  "description": "Dark mode themes for Classtab.org",
  "permissions": [
    "activeTab",
    "declarativeContent",
    "storage"
  ],
  "host_permissions": [
    "https://www.classtab.org/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.classtab.org/*"
      ],
      "js": [
        "js/content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "css/app.css",
        "css/popup.css",
        "fonts/CutiveMono-Regular.ttf",
        "fonts/NovaMono-Regular.ttf",
        "fonts/RobotoMono-Regular.ttf",
        "fonts/UbuntuMono-Regular.ttf",
        "img/logo-16.png",
        "img/logo-32.png",
        "img/logo-48.png",
        "img/logo-64.png",
        "img/logo-128.png",
        "js/content.js",
        "js/popup.js"
      ],
      "matches": [
        "*://*/*"
      ]
    }
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_icon": {
      "16": "img/logo-16.png",
      "32": "img/logo-32.png",
      "48": "img/logo-48.png",
      "64": "img/logo-64.png",
      "128": "img/logo-128.png"
    },
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "img/logo-16.png",
    "32": "img/logo-32.png",
    "48": "img/logo-48.png",
    "64": "img/logo-64.png",
    "128": "img/logo-128.png"
  },
  "manifest_version": 3
}